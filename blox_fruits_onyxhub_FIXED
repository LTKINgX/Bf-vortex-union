function UI_SYSTEM.createToggle(parent, text, positionY, stateTable, stateKey, callback)
    local frame = UTILS.createWithStaticStroke("Frame", parent, {
        Name = text .. "Toggle", Size = UDim2.new(1, -20, 0, 45),
        Position = UDim2.new(0, 10, 0, positionY),
        BackgroundColor3 = Color3.fromRGB(35, 25, 45), BackgroundTransparency = 0.5, ZIndex = 5
    })
    UTILS.createInstance("UICorner", frame, {CornerRadius = UDim.new(0, 8)})
    UTILS.createInstance("TextLabel", frame, {
        Text = text, Size = UDim2.new(1, -60, 1, 0), Position = UDim2.new(0, 15, 0, 0),
        BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(230, 230, 230),
        TextSize = 14, Font = Enum.Font.Gotham, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6
    })
    local switchBg = UTILS.createInstance("Frame", frame, {
        Size = UDim2.new(0, 40, 0, 20), Position = UDim2.new(1, -55, 0.5, -10),
        BackgroundColor3 = stateTable[stateKey] and CONFIG.MAIN_COLOR or Color3.fromRGB(60, 50, 70),
        ZIndex = 6, BorderSizePixel = 0
    })
    UTILS.createInstance("UICorner", switchBg, {CornerRadius = UDim.new(1, 0)})
    local ball = UTILS.createInstance("Frame", switchBg, {
        Size = UDim2.new(0, 16, 0, 16),
        Position = stateTable[stateKey] and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255), ZIndex = 7, BorderSizePixel = 0
    })
    UTILS.createInstance("UICorner", ball, {CornerRadius = UDim.new(1, 0)})
    local btn = UTILS.createInstance("TextButton", frame, {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 8
    })
    btn.MouseButton1Click:Connect(function()
        stateTable[stateKey] = not stateTable[stateKey]
        local on = stateTable[stateKey]
        TweenService:Create(switchBg, TweenInfo.new(0.3), {
            BackgroundColor3 = on and CONFIG.MAIN_COLOR or Color3.fromRGB(60, 50, 70)
        }):Play()
        TweenService:Create(ball, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
            Position = on and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        }):Play()
        if callback then task.spawn(callback, on) end
        UTILS.playClickSound()
    end)
    btn.MouseEnter:Connect(function()
        TweenService:Create(frame, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(45, 35, 55), BackgroundTransparency = 0.3
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(frame, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(35, 25, 45), BackgroundTransparency = 0.5
        }):Play()
    end)
    return frame, btn
end

function UI_SYSTEM.createSlider(parent, title, defaultValue, minValue, maxValue, rounding, callback)
    local Y = 0 -- This will be managed by the calling function
    local sliderContainer = UTILS.createWithStaticStroke("Frame", parent, {
        BackgroundColor3 = Color3.fromRGB(40, 30, 55), BackgroundTransparency = 0.3,
        BorderSizePixel = 0, Size = UDim2.new(1, -20, 0, 60),
        Position = UDim2.new(0, 10, 0, Y), ZIndex = 5
    })
    UTILS.createInstance("UICorner", sliderContainer, {CornerRadius = UDim.new(0, 8)})

    local titleLabel = UTILS.createInstance("TextLabel", sliderContainer, {
        Text = title, TextColor3 = Color3.fromRGB(240, 230, 250), TextSize = 14,
        Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Size = UDim2.new(0.7, 0, 0, 20),
        Position = UDim2.new(0, 10, 0, 5), TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6
    })

    local valueLabel = UTILS.createInstance("TextLabel", sliderContainer, {
        Text = tostring(defaultValue), TextColor3 = CONFIG.MAIN_COLOR, TextSize = 14,
        Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Size = UDim2.new(0.3, -20, 0, 20),
        Position = UDim2.new(0.7, 0, 0, 5), TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 6
    })

    local sliderBg = UTILS.createInstance("Frame", sliderContainer, {
        Size = UDim2.new(1, -20, 0, 10), Position = UDim2.new(0, 10, 0, 30),
        BackgroundColor3 = Color3.fromRGB(60, 50, 70), ZIndex = 6, BorderSizePixel = 0
    })
    UTILS.createInstance("UICorner", sliderBg, {CornerRadius = UDim.new(1, 0)})

    local sliderFill = UTILS.createInstance("Frame", sliderBg, {
        Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0),
        BackgroundColor3 = CONFIG.MAIN_COLOR, ZIndex = 7, BorderSizePixel = 0
    })
    UTILS.createInstance("UICorner", sliderFill, {CornerRadius = UDim.new(1, 0)})

    local thumb = UTILS.createInstance("Frame", sliderBg, {
        Size = UDim2.new(0, 20, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 0.5, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255), ZIndex = 15, BorderSizePixel = 0
    })
    UTILS.createInstance("UICorner", thumb, {CornerRadius = UDim.new(1, 0)})
    UTILS.createInstance("UIStroke", thumb, {Thickness = 2, Color = CONFIG.MAIN_COLOR})

    local isDrag = false
    local function updateSlider(inputX)
        local width = sliderBg.AbsoluteSize.X
        local newX = math.clamp(inputX - sliderBg.AbsolutePosition.X, 0, width)
        local percentage = newX / width
        local value = minValue + (maxValue - minValue) * percentage
        if rounding then value = math.floor(value / rounding) * rounding end
        value = math.clamp(value, minValue, maxValue)

        TweenService:Create(sliderFill, TweenInfo.new(0.05), {Size = UDim2.new((value - minValue) / (maxValue - minValue), 0, 1, 0)}):Play()
        TweenService:Create(thumb, TweenInfo.new(0.05), {Position = UDim2.new((value - minValue) / (maxValue - minValue), 0, 0.5, 0)}):Play()
        valueLabel.Text = tostring(value)
        if callback then callback(value) end
    end

    local clickDetector = UTILS.createInstance("TextButton", sliderContainer, {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 10
    })
    clickDetector.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDrag = true
            updateSlider(input.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDrag = false
        end
    end)

    return sliderContainer
end

