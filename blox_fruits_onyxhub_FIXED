function UTILS.playClickSound()
    local s = Instance.new("Sound"); s.SoundId = "rbxassetid://138656262630730"
    s.Volume = 0.7; s.Parent = SoundService; s:Play(); Debris:AddItem(s, 2)
end

function UTILS.showNotification(title, message, duration)
    duration = duration or 5
    local s = Instance.new("Sound"); s.SoundId = "rbxassetid://106553517979212"
    s.Volume = 0.5; s.Parent = SoundService; s:Play(); Debris:AddItem(s, 3)
    if not UI_ELEMENTS.ScreenGui then
        UI_ELEMENTS.ScreenGui = UTILS.createInstance("ScreenGui", CoreGui, {
            Name = "BloxFruitsGUI", ZIndexBehavior = Enum.ZIndexBehavior.Global,
            ResetOnSpawn = false, DisplayOrder = 100
        })
    end
    local function updateStack()
        for i, f in ipairs(ActiveNotifications) do
            if f and f.Parent then
                local targetY = -105 - ((#ActiveNotifications - i) * NOTIFICATION_HEIGHT)
                TweenService:Create(f, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                    {Position = UDim2.new(1, -300, 1, targetY)}):Play()
            end
        end
    end
    local function removeNotif(nf)
        local idx = table.find(ActiveNotifications, nf)
        if idx then
            table.remove(ActiveNotifications, idx)
            nf:TweenPosition(UDim2.new(1, 300, nf.Position.Y.Scale, nf.Position.Y.Offset),
                "In", "Quad", 0.4, true, function() nf:Destroy(); updateStack() end)
        end
    end
    if #ActiveNotifications >= 5 then
        local old = ActiveNotifications[1]
        if old then removeNotif(old); task.wait(0.1) end
    end
    local nf = UTILS.createWithStaticStroke("Frame", UI_ELEMENTS.ScreenGui, {
        Name = "Notification", Size = UDim2.new(0, 280, 0, 75),
        Position = UDim2.new(1, 20, 1, -105),
        BackgroundColor3 = Color3.fromRGB(25, 15, 35), BackgroundTransparency = 0.1,
        ZIndex = 100, ClipsDescendants = true
    })
    UTILS.createInstance("UICorner", nf, {CornerRadius = UDim.new(0, 10)})
    UTILS.createInstance("TextLabel", nf, {
        Text = title, Size = UDim2.new(1, -40, 0, 22), Position = UDim2.new(0, 10, 0, 6),
        BackgroundTransparency = 1, TextColor3 = CONFIG.MAIN_COLOR, TextSize = 15,
        Font = Enum.Font.GothamBold, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 101
    })
    UTILS.createInstance("TextLabel", nf, {
        Text = message, Size = UDim2.new(1, -40, 0, 28), Position = UDim2.new(0, 10, 0, 28),
        BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(245, 235, 255), TextSize = 13,
        Font = Enum.Font.Gotham, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top, ZIndex = 101
    })
    local pc = UTILS.createInstance("Frame", nf, {
        Size = UDim2.new(1, -70, 0, 3), Position = UDim2.new(0, 10, 1, -10),
        BackgroundColor3 = Color3.fromRGB(40, 30, 55), BackgroundTransparency = 0.3,
        BorderSizePixel = 0, ZIndex = 102
    })
    UTILS.createInstance("UICorner", pc, {CornerRadius = UDim.new(1, 0)})
    local pb = UTILS.createInstance("Frame", pc, {
        Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = CONFIG.MAIN_COLOR,
        BorderSizePixel = 0, ZIndex = 103
    })
    UTILS.createInstance("UICorner", pb, {CornerRadius = UDim.new(1, 0)})
    local closeBtn = UTILS.createInstance("TextButton", nf, {
        Size = UDim2.new(0, 24, 0, 24), Position = UDim2.new(1, -28, 0, 6),
        BackgroundColor3 = Color3.fromRGB(60, 40, 80), BackgroundTransparency = 0.3,
        Text = "×", TextColor3 = Color3.fromRGB(220, 220, 220), TextSize = 18,
        Font = Enum.Font.GothamBold, ZIndex = 105, AutoButtonColor = false
    })
    UTILS.createInstance("UICorner", closeBtn, {CornerRadius = UDim.new(1, 0)})
    closeBtn.MouseButton1Click:Connect(function() UTILS.playClickSound(); removeNotif(nf) end)
    table.insert(ActiveNotifications, nf); updateStack()
    local startT = tick()
    local pc2; pc2 = RunService_OH.Heartbeat:Connect(function()
        if not nf or not nf.Parent then if pc2 then pc2:Disconnect() end return end
        local rem = math.max(0, duration - (tick() - startT))
        pb.Size = UDim2.new(rem / duration, 0, 1, 0)
    end)
    task.delay(duration, function()
        if nf and nf.Parent then removeNotif(nf) end
        if pc2 then pc2:Disconnect() end
    end)
    return nf
end

function UTILS.createInstance(className, parent, properties)
    local obj = Instance.new(className, parent)
    for k, v in pairs(properties) do obj[k] = v end
    return obj
end

function UTILS.createWithStaticStroke(className, parent, properties)
    local obj = UTILS.createInstance(className, parent, properties)
    if className == "Frame" or className == "TextButton" or className == "ScrollingFrame" then
        local STROKE_GRADIENT = {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0,   CONFIG.MAIN_COLOR),
                ColorSequenceKeypoint.new(0.3, CONFIG.MAIN_COLOR),
                ColorSequenceKeypoint.new(0.7, CONFIG.MAIN_COLOR),
                ColorSequenceKeypoint.new(1,   CONFIG.MAIN_COLOR)
            }),
            Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0,   0),
                NumberSequenceKeypoint.new(0.2, 0),
                NumberSequenceKeypoint.new(0.5, 0.5),
                NumberSequenceKeypoint.new(0.8, 0.8),
                NumberSequenceKeypoint.new(1,   1)
            })
        }
        local s = UTILS.createInstance("UIStroke", obj, {Thickness = 2, Color = Color3.fromRGB(255, 255, 255),
            Transparency = 0, ApplyStrokeMode = Enum.ApplyStrokeMode.Border})
        UTILS.createInstance("UIGradient", s, {Color = STROKE_GRADIENT.Color,
            Transparency = STROKE_GRADIENT.Transparency, Rotation = 0})
    end
    return obj
end

function UTILS.updateCanvasSize(sf, cf)
    if not sf or not cf or not sf:IsA("ScrollingFrame") then return end
    local h = 0
    for _, c in ipairs(cf:GetChildren()) do if c:IsA("GuiObject") then h = h + c.AbsoluteSize.Y end end
    sf.CanvasSize = UDim2.new(0, 0, 0, h + 100); cf.Size = UDim2.new(1, 0, 0, h + 80)
end

function UTILS.updateTabButtonsContainerSize(c)
    local h = 0
    for _, ch in ipairs(c:GetChildren()) do if ch:IsA("GuiObject") then h = h + ch.AbsoluteSize.Y + 8 end end
    c.CanvasSize = UDim2.new(0, 0, 0, h)
end

