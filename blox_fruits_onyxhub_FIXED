function UI_SYSTEM.createInput(parent, title, defaultValue, callback)
    local inputContainer = UTILS.createWithStaticStroke("Frame", parent, {
        BackgroundColor3 = Color3.fromRGB(40, 30, 55), BackgroundTransparency = 0.3,
        BorderSizePixel = 0, Size = UDim2.new(1, -20, 0, CONFIG.BUTTON_HEIGHT),
        Position = UDim2.new(0, 10, 0, 0), ZIndex = 5
    })
    UTILS.createInstance("UICorner", inputContainer, {CornerRadius = UDim.new(0, 8)})

    local inputTextBox = UTILS.createInstance("TextBox", inputContainer, {
        Text = defaultValue or "", TextColor3 = Color3.fromRGB(230, 230, 230), TextSize = 14,
        Font = Enum.Font.Gotham, BackgroundTransparency = 1, Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.new(0, 10, 0, 0), TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
        ClearTextOnFocus = false
    })

    inputTextBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            UTILS.playClickSound()
            if callback then callback(inputTextBox.Text) end
        end
    end)

    return inputContainer
end

