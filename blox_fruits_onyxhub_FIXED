function UI_SYSTEM.createDropdown(parent, title, values, multi, defaultValue, callback)
    local dropdownContainer = UTILS.createWithStaticStroke("Frame", parent, {
        BackgroundColor3 = Color3.fromRGB(40, 30, 55), BackgroundTransparency = 0.3,
        BorderSizePixel = 0, Size = UDim2.new(1, -20, 0, CONFIG.BUTTON_HEIGHT),
        Position = UDim2.new(0, 10, 0, 0), ZIndex = 5
    })
    UTILS.createInstance("UICorner", dropdownContainer, {CornerRadius = UDim.new(0, 8)})

    local selectedText = UTILS.createInstance("TextLabel", dropdownContainer, {
        Text = defaultValue or "Select an option", TextColor3 = Color3.fromRGB(230, 230, 230), TextSize = 14,
        Font = Enum.Font.Gotham, BackgroundTransparency = 1, Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, 10, 0, 0), TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6
    })

    local arrow = UTILS.createInstance("TextLabel", dropdownContainer, {
        Text = "▼", TextColor3 = Color3.fromRGB(230, 230, 230), TextSize = 14,
        Font = Enum.Font.Gotham, BackgroundTransparency = 1, Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(1, -30, 0, 0), TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 6
    })

    local dropdownButton = UTILS.createInstance("TextButton", dropdownContainer, {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 8
    })

    local optionsFrame = nil
    local isOpen = false

    local function closeDropdown()
        if optionsFrame then
            optionsFrame:Destroy()
            optionsFrame = nil
            isOpen = false
            arrow.Text = "▼"
        end
    end

    dropdownButton.MouseButton1Click:Connect(function()
        UTILS.playClickSound()
        if isOpen then
            closeDropdown()
        else
            -- Create options frame
            optionsFrame = UTILS.createWithStaticStroke("Frame", dropdownContainer.Parent, {
                BackgroundColor3 = Color3.fromRGB(30, 20, 40), BackgroundTransparency = 0.1,
                BorderSizePixel = 0, Size = UDim2.new(dropdownContainer.Size.X.Scale, dropdownContainer.Size.X.Offset, 0, #values * 30),
                Position = UDim2.new(dropdownContainer.Position.X.Scale, dropdownContainer.Position.X.Offset, 0, dropdownContainer.Position.Y.Offset + dropdownContainer.Size.Y.Offset + CONFIG.SPACING),
                ZIndex = 10
            })
            UTILS.createInstance("UICorner", optionsFrame, {CornerRadius = UDim.new(0, 8)})

            local currentY = 0
            for i, value in ipairs(values) do
                local optionButton = UTILS.createInstance("TextButton", optionsFrame, {
                    Size = UDim2.new(1, 0, 0, 30), Position = UDim2.new(0, 0, 0, currentY),
                    BackgroundColor3 = Color3.fromRGB(35, 25, 45), BackgroundTransparency = 1,
                    Text = value, TextColor3 = Color3.fromRGB(230, 230, 230), TextSize = 14,
                    Font = Enum.Font.Gotham, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 11
                })
                optionButton.MouseButton1Click:Connect(function()
                    UTILS.playClickSound()
                    selectedText.Text = value
                    if callback then callback(value) end
                    closeDropdown()
                end)
                currentY = currentY + 30
            end
            isOpen = true
            arrow.Text = "▲"
        end
    end)

    return dropdownContainer
end

